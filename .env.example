# Required
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional (defaults shown)
RAPIDAPI_KEY=
RIFTCODEX_PROXY_URL=                    # Cloudflare Worker proxy for Riftcodex API
NODE_ENV=development
PORT=8080
# WEBHOOK_URL=https://your-app.example.com

# Cache TTLs (hours)
CACHE_TTL_CARD_HOURS=168
CACHE_TTL_SEARCH_HOURS=24
CACHE_TTL_SET_HOURS=168

# API behavior
API_TIMEOUT_MS=10000
API_RETRY_ATTEMPTS=3
