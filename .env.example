# riftcards-bot configuration
#
# All variables are namespaced; the only one without a namespace is
# TELEGRAM_BOT_TOKEN, which the underlying telegraf library reads
# directly. Copy to .env and fill in the secrets. .env is gitignored.

# --- Required ---

TELEGRAM_BOT_TOKEN=your_bot_token_here

# Which card data source the bot talks to. Must be set; the bot
# fails fast at startup if this is missing or unrecognised. See
# ADR-0004.
CARD_SOURCE=riftapi

# Base URL of the chosen card source. Required.
# Examples: http://riftapi:8080  (same-host Docker)
#           https://riftcodex.example.com  (self-hosted fallback)
RIFTAPI_BASE_URL=
# RIFTCODEX_BASE_URL=                  # only required when CARD_SOURCE=riftcodex

# --- Optional (defaults shown) ---

NODE_ENV=development
PORT=8080
# WEBHOOK_URL=https://your-app.example.com  # required when NODE_ENV=production

# --- API behavior ---

API_TIMEOUT_MS=10000
API_RETRY_ATTEMPTS=3

# --- Events adapter ---
#
# Defaults point at Seville, Spain, with a 50 mi / 7-day window.
# EVENTS_API_URL defaults to the upstream's Cloudflare-fronted URL;
# the Cloudflare Worker proxy hop is removed.

# EVENTS_API_URL=https://api.cloudflare.riftbound.uvsgames.com
# EVENTS_LATITUDE=37.39
# EVENTS_LONGITUDE=-5.99
# EVENTS_RADIUS_KM=80
# EVENTS_DAYS_AHEAD=7
