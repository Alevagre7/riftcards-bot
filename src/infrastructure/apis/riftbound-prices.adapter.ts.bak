import { z } from 'zod';
import { IPriceRepository } from '../../core/ports/price-repository.js';
import { PriceData } from '../../core/entities/price.js';
import { ICacheService } from '../../core/ports/cache-service.js';
import { ApiTimeoutError, ApiResponseError, ApiRateLimitError } from '../../core/errors/index.js';
import { DomainError } from '../../core/errors/base-error.js';
import { fetchWithRetry } from '../../utils/api-client.js';

const RapidApiCardPriceSchema = z.object({
  id: z.number(),
  name: z.string(),
});

const RapidApiSearchResponseSchema = z.object({
  data: z.array(RapidApiCardPriceSchema),
});

type RapidApiCardPrice = z.infer<typeof RapidApiCardPriceSchema>;

interface RiftboundPricesAdapterOptions {
  baseUrl: string;
  apiKey: string;
  cache: ICacheService;
  timeoutMs: number;
  retryAttempts: number;
}

function priceSummary(raw: Record<string, unknown>): string {
  const cm = (raw.prices as Record<string, unknown> | null)?.cardmarket as Record<string, unknown> | null;
  const eu = cm?.lowest_near_mint_EU_only;
  const a30 = cm?.['30d_average'];
  const a7 = cm?.['7d_average'];
  const cn = raw.card_number || raw.card_code_number || '?';
  return `[${cn}] EU=${eu ?? '-'} 30d=${a30 ?? '-'} 7d=${a7 ?? '-'}`;
}

export class RiftboundPricesAdapter implements IPriceRepository {
  constructor(private options: RiftboundPricesAdapterOptions) {}

  async getPrice(
    cardIdentifier: string,
    options?: { setCode?: string; collectorNumber?: string },
  ): Promise<PriceData | null> {
    const cacheKey = `price:${encodeURIComponent(cardIdentifier.toLowerCase())}`;
    const cached = await this.options.cache.get<PriceData>(cacheKey);
    if (cached) {
      console.log(`[prices] cache hit: "${cardIdentifier}"`);
      return cached;
    }

    const params = new URLSearchParams();
    params.set('search', cardIdentifier);
    const url = `${this.options.baseUrl}/cards/search?${params.toString()}`;

    const host = new URL(this.options.baseUrl).host;

    try {
      const response = await fetchWithRetry(url, {
        timeout: this.options.timeoutMs,
        retries: this.options.retryAttempts,
        headers: {
          Accept: 'application/json',
          'X-RapidAPI-Key': this.options.apiKey,
          'X-RapidAPI-Host': host,
        },
      });

      if (response.status === 429) {
        throw new ApiRateLimitError();
      }

      if (response.status === 404) {
        console.log(`[prices] 404 for "${cardIdentifier}"`);
        return null;
      }

      if (!response.ok) {
        throw new ApiResponseError('Riftbound Prices', response.status);
      }

      const json = await response.json();
      const parsed = RapidApiSearchResponseSchema.parse(json);

      const rawDataArray = json.data as Record<string, unknown>[];
      console.log(`[prices] "${cardIdentifier}" => ${rawDataArray.length} results`);

      if (rawDataArray.length === 0) {
        return null;
      }

      let raw = rawDataArray[0]!;
      let matchMethod = 'first';

      if (options?.setCode && options?.collectorNumber) {
        const prefix = `${options.setCode}-${options.collectorNumber}`.toLowerCase();
        const match = rawDataArray.find((item) => {
          const cn = typeof item.card_number === 'string' ? item.card_number : '';
          const ccn = typeof item.card_code_number === 'string' ? item.card_code_number : '';
          return cn.toLowerCase().startsWith(prefix) || ccn.toLowerCase().startsWith(prefix);
        });
        if (match) {
          raw = match;
          matchMethod = `variant:${prefix}`;
        }
      }

      console.log(`[prices] matched ${matchMethod} ${priceSummary(raw)}`);

      const priceData = this.mapToDomain(raw);

      const hasAny =
        priceData.lowestNearMintEuOnly !== null ||
        priceData.average30d !== null ||
        priceData.average7d !== null;

      if (!hasAny && rawDataArray.length > 1 && rawDataArray[0] !== raw) {
        console.log(`[prices] variant has no prices, trying fallback data[0]`);
        const fallback = this.mapToDomain(rawDataArray[0]!);
        const fbHas =
          fallback.lowestNearMintEuOnly !== null ||
          fallback.average30d !== null ||
          fallback.average7d !== null;
        if (fbHas) {
          console.log(`[prices] fallback success ${priceSummary(rawDataArray[0]!)}`);
          await this.options.cache.set(cacheKey, fallback, 60 * 60);
          return fallback;
        }
        console.log(`[prices] fallback also empty`);
      }

      await this.options.cache.set(cacheKey, priceData, 60 * 60);
      return priceData;
    } catch (error) {
      if (error instanceof DomainError) throw error;
      console.error(`[prices] fetch failed for "${cardIdentifier}":`, error);
      throw new ApiTimeoutError('Riftbound Prices');
    }
  }

  private mapToDomain(raw: Record<string, unknown>): PriceData {
    const id = typeof raw.id === 'number' ? raw.id : (typeof raw.id === 'string' ? Number(raw.id) : 0);
    const name = typeof raw.name === 'string' ? raw.name : '';

    const prices = raw.prices as Record<string, unknown> | null | undefined;
    const cardmarket = prices?.cardmarket as Record<string, unknown> | null | undefined;

    const currency = typeof cardmarket?.currency === 'string' ? cardmarket.currency : 'EUR';

    const toNumberOrNull = (v: unknown): number | null =>
      typeof v === 'number' && Number.isFinite(v) ? v : null;

    const gradedRaw = cardmarket?.graded as unknown[] | undefined;
    const gradedPrices = gradedRaw?.map((g: unknown) => {
      const item = g as Record<string, unknown>;
      return {
        gradingCompany: typeof item.grading_company === 'string' ? item.grading_company : '',
        grade: typeof item.grade === 'string' ? item.grade : '',
        price: typeof item.price === 'number' ? item.price : 0,
      };
    });

    const links = raw.links as Record<string, unknown> | null | undefined;
    const cardmarketUrl = links && typeof links.cardmarket === 'string' ? links.cardmarket : null;

    return {
      cardId: String(id),
      cardName: name,
      currency,
      lowestNearMint: toNumberOrNull(cardmarket?.lowest_near_mint),
      lowestNearMintEuOnly: toNumberOrNull(cardmarket?.lowest_near_mint_EU_only),
      average30d: toNumberOrNull(cardmarket?.['30d_average']),
      average7d: toNumberOrNull(cardmarket?.['7d_average']),
      ...(gradedPrices != null && gradedPrices.length > 0
        ? { gradedPrices }
        : {}),
      ...(cardmarketUrl != null
        ? { cardmarketUrl }
        : {}),
    };
  }
}
